  (symbol (lib_id "Sensor:Piezo") (at 120 90) (property "Reference" "VIB5"))

  ; Flex sensors
  (symbol (lib_id "Device:R_Potentiometer") (at 170 30) (property "Reference" "FS1"))
  (symbol (lib_id "Device:R_Potentiometer") (at 170 45) (property "Reference" "FS2"))
  (symbol (lib_id "Device:R_Potentiometer") (at 170 60) (property "Reference" "FS3"))

#include <Servo.h>

// Déclaration des servos
Servo thumb;
Servo indexF;
Servo middle;
Servo ring;
Servo pinky;

// EMG
const int emgPin = A0;
int rawValue = 0;
float signal = 0;

// Calibration
int threshold = 520;   // à ajuster selon ton capteur

// Positions servos (à ajuster selon ta mécanique)
int openPos  = 10;     // main ouverte
int closePos = 170;    // main fermée

void setup() {
  Serial.begin(115200);

  // Attacher les servos aux pins
  thumb.attach(3);
  indexF.attach(5);
  middle.attach(6);
  ring.attach(9);
  pinky.attach(10);

  // Position initiale : main ouverte
  openHand();
  delay(1000);
}

void loop() {
  // 1. Lire EMG
  rawValue = analogRead(emgPin);

  // 2. Smoothing (filtre simple)
  signal = (signal * 0.9) + (rawValue * 0.1);

  // Debug série
  Serial.println(signal);

  // 3. Détection de seuil
  if (signal > threshold) {
    closeHand();   // fermer la main
  } else {
    openHand();    // ouvrir la main
  }

  delay(15); // petit délai pour stabiliser
}

void openHand() {
  thumb.write(openPos);
  indexF.write(openPos);
  middle.write(openPos);
  ring.write(openPos + 10);   // petit offset si besoin
  pinky.write(openPos + 20);  // petit offset si besoin
}

void closeHand() {
  thumb.write(closePos);
  indexF.write(closePos);
  middle.write(closePos);
  ring.write(closePos - 10);
  pinky.write(closePos - 20);
}
